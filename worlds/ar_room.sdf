<?xml version="1.0" ?>
<!--
  AR Tag Room — Gazebo Ignition Fortress
  ========================================
  Room     : 6 m × 5 m × 3 m (interior dimensions)
  Tags     : 8 orange boxes on walls, all ID 0, asymmetrically placed
  Robot    : simple differential-drive, 0.4 m × 0.3 m chassis, front camera
-->
<sdf version="1.8">
<world name="ar_room">

  <!-- ── Physics & core plugins ─────────────────────────────────────── -->
  <physics name="1ms" type="ignored">
    <max_step_size>0.004</max_step_size>
    <real_time_factor>1.0</real_time_factor>
  </physics>

  <plugin filename="libignition-gazebo-physics-system.so"
          name="ignition::gazebo::systems::Physics"/>
  <plugin filename="libignition-gazebo-user-commands-system.so"
          name="ignition::gazebo::systems::UserCommands"/>
  <plugin filename="libignition-gazebo-scene-broadcaster-system.so"
          name="ignition::gazebo::systems::SceneBroadcaster"/>
  <plugin filename="libignition-gazebo-sensors-system.so"
          name="ignition::gazebo::systems::Sensors">
    <render_engine>ogre2</render_engine>
  </plugin>

  <!-- ── Lighting ───────────────────────────────────────────────────── -->
  <light type="directional" name="sun">
    <cast_shadows>true</cast_shadows>
    <pose>0 0 10 0 0 0</pose>
    <diffuse>0.85 0.85 0.85 1</diffuse>
    <specular>0.2 0.2 0.2 1</specular>
    <direction>-0.5 0.1 -0.9</direction>
  </light>
  <light type="point" name="room_light">
    <pose>0 0 2.8 0 0 0</pose>
    <diffuse>0.7 0.7 0.7 1</diffuse>
    <specular>0.1 0.1 0.1 1</specular>
    <attenuation>
      <range>10</range>
      <constant>0.5</constant>
      <linear>0.01</linear>
      <quadratic>0.001</quadratic>
    </attenuation>
  </light>

  <!-- ── Floor ──────────────────────────────────────────────────────── -->
  <model name="floor">
    <static>true</static>
    <pose>0 0 -0.05 0 0 0</pose>
    <link name="link">
      <visual name="visual">
        <geometry><box><size>6.2 5.2 0.10</size></box></geometry>
        <material>
          <ambient>0.60 0.60 0.55 1</ambient>
          <diffuse>0.60 0.60 0.55 1</diffuse>
          <specular>0.05 0.05 0.05 1</specular>
        </material>
      </visual>
      <collision name="collision">
        <geometry><box><size>6.2 5.2 0.10</size></box></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction>
        </surface>
      </collision>
    </link>
  </model>

  <!-- ── Walls ──────────────────────────────────────────────────────── -->
  <!-- South wall  y = -2.5 -->
  <model name="wall_south">
    <static>true</static>
    <pose>0 -2.55 1.5 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>6.1 0.10 3.0</size></box></geometry>
        <material><ambient>0.75 0.75 0.72 1</ambient><diffuse>0.75 0.75 0.72 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>6.1 0.10 3.0</size></box></geometry>
      </collision>
    </link>
  </model>

  <!-- North wall  y = +2.5 -->
  <model name="wall_north">
    <static>true</static>
    <pose>0 2.55 1.5 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>6.1 0.10 3.0</size></box></geometry>
        <material><ambient>0.75 0.75 0.72 1</ambient><diffuse>0.75 0.75 0.72 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>6.1 0.10 3.0</size></box></geometry>
      </collision>
    </link>
  </model>

  <!-- West wall  x = -3.0 -->
  <model name="wall_west">
    <static>true</static>
    <pose>-3.05 0 1.5 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.10 5.1 3.0</size></box></geometry>
        <material><ambient>0.72 0.72 0.75 1</ambient><diffuse>0.72 0.72 0.75 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.10 5.1 3.0</size></box></geometry>
      </collision>
    </link>
  </model>

  <!-- East wall  x = +3.0 -->
  <model name="wall_east">
    <static>true</static>
    <pose>3.05 0 1.5 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.10 5.1 3.0</size></box></geometry>
        <material><ambient>0.72 0.72 0.75 1</ambient><diffuse>0.72 0.72 0.75 1</diffuse></material>
      </visual>
      <collision name="c">
        <geometry><box><size>0.10 5.1 3.0</size></box></geometry>
      </collision>
    </link>
  </model>

  <!--
    ══════════════════════════════════════════════════════════════
    AR TAGS — 8 orange boxes, all "ID 0" (same appearance).
    Positions match constants.py TAG_POSITIONS.
    ══════════════════════════════════════════════════════════════
  -->

  <!-- tag 0 — South wall, left   (-1.50, -2.40, 1.0) -->
  <model name="tag_S1">
    <static>true</static>
    <pose>-1.50 -2.46 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.25 0.03 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!-- tag 1 — South wall, right  ( 1.20, -2.40, 1.0) -->
  <model name="tag_S2">
    <static>true</static>
    <pose>1.20 -2.46 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.25 0.03 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!-- tag 2 — North wall, left  (-0.30, +2.40, 1.0) -->
  <model name="tag_N1">
    <static>true</static>
    <pose>-0.30 2.46 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.25 0.03 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!-- tag 3 — North wall, right  ( 2.00, +2.40, 1.0) -->
  <model name="tag_N2">
    <static>true</static>
    <pose>2.00 2.46 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.25 0.03 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!-- tag 4 — West wall, bottom  (-2.90, -0.50, 1.0) -->
  <model name="tag_W1">
    <static>true</static>
    <pose>-2.96 -0.50 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.03 0.25 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!-- tag 5 — West wall, top     (-2.90, +1.50, 1.0) -->
  <model name="tag_W2">
    <static>true</static>
    <pose>-2.96 1.50 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.03 0.25 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!-- tag 6 — East wall, top     (+2.90, +0.50, 1.0) -->
  <model name="tag_E1">
    <static>true</static>
    <pose>2.96 0.50 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.03 0.25 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!-- tag 7 — East wall, bottom  (+2.90, -1.50, 1.0) -->
  <model name="tag_E2">
    <static>true</static>
    <pose>2.96 -1.50 1.0 0 0 0</pose>
    <link name="link">
      <visual name="v">
        <geometry><box><size>0.03 0.25 0.25</size></box></geometry>
        <material>
          <ambient>1 1 1 1</ambient>
          <diffuse>1 1 1 1</diffuse>
          <specular>0 0 0 1</specular>
          <pbr>
            <metal>
              <albedo_map>file://materials/textures/aruco_id0.png</albedo_map>
            </metal>
          </pbr>
        </material>
      </visual>
    </link>
  </model>

  <!--
    ══════════════════════════════════════════════════════════════
    ROBOT — differential drive, starts at (0, 0, 0)
    Chassis  : 0.40 × 0.30 × 0.10 m  (blue box)
    Wheels   : radius 0.075 m  (grey cylinders)
    Caster   : radius 0.030 m  (rear)
    Camera   : forward-facing, 60° FOV, 640×480
    ══════════════════════════════════════════════════════════════
  -->
  <model name="robot">
    <!-- Start position: centre of room, facing east (+x) -->
    <pose>0 0 0 0 0 0</pose>

    <!-- ── Chassis ──────────────────────────────────────────────── -->
    <link name="chassis">
      <!-- centre at z = wheel_radius + half_chassis = 0.075 + 0.05 = 0.125 -->
      <pose>0 0 0.125 0 0 0</pose>
      <inertial>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.0200</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0467</iyy><iyz>0</iyz>
          <izz>0.0567</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><box><size>0.40 0.30 0.10</size></box></geometry>
        <material>
          <ambient>0.10 0.30 0.90 1</ambient>
          <diffuse>0.10 0.30 0.90 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><box><size>0.40 0.30 0.10</size></box></geometry>
      </collision>

      <!-- ── Camera sensor (forward-facing) ── -->
      <sensor name="camera" type="camera">
        <!-- mounted at front-centre of chassis, 5 cm above chassis top -->
        <pose>0.00 0 0.12 0 -0.40 0</pose>
        <camera>
          <horizontal_fov>1.0472</horizontal_fov>  <!-- 60° -->
          <image>
            <width>640</width>
            <height>480</height>
          </image>
          <clip><near>0.05</near><far>10.0</far></clip>
        </camera>
        <always_on>true</always_on>
        <update_rate>10</update_rate>
        <visualize>false</visualize>
        <topic>/camera/image</topic>
      </sensor>
    </link>

    <!-- ── Left wheel ───────────────────────────────────────────── -->
    <link name="left_wheel">
      <pose>0 0.185 0.075 -1.5707963 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.000844</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000844</iyy><iyz>0</iyz>
          <izz>0.001519</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction>
        </surface>
      </collision>
    </link>

    <!-- ── Right wheel ──────────────────────────────────────────── -->
    <link name="right_wheel">
      <pose>0 -0.185 0.075 -1.5707963 0 0</pose>
      <inertial>
        <mass>0.3</mass>
        <inertia>
          <ixx>0.000844</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000844</iyy><iyz>0</iyz>
          <izz>0.001519</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <material><ambient>0.2 0.2 0.2 1</ambient><diffuse>0.2 0.2 0.2 1</diffuse></material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.075</radius><length>0.04</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>0.5</mu2></ode></friction>
        </surface>
      </collision>
    </link>

    <!-- ── Rear caster ──────────────────────────────────────────── -->
    <link name="caster">
      <pose>-0.15 0 0.030 0 0 0</pose>
      <inertial>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.000012</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.000012</iyy><iyz>0</iyz>
          <izz>0.000012</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><sphere><radius>0.030</radius></sphere></geometry>
        <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
      </visual>
      <collision name="collision">
        <geometry><sphere><radius>0.030</radius></sphere></geometry>
        <surface>
          <friction><ode><mu>0.001</mu><mu2>0.001</mu2></ode></friction>
        </surface>
      </collision>
    </link>

    <!-- ── Joints ───────────────────────────────────────────────── -->
    <joint name="left_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>left_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>   <!-- local z of rotated wheel = world y -->
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><friction>0.01</friction></dynamics>
      </axis>
    </joint>

    <joint name="right_wheel_joint" type="revolute">
      <parent>chassis</parent>
      <child>right_wheel</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit><lower>-1e16</lower><upper>1e16</upper></limit>
        <dynamics><friction>0.01</friction></dynamics>
      </axis>
    </joint>

    <joint name="caster_joint" type="ball">
      <parent>chassis</parent>
      <child>caster</child>
    </joint>

    <!-- ── Plugins ──────────────────────────────────────────────── -->
    <plugin filename="libignition-gazebo-diff-drive-system.so"
            name="ignition::gazebo::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.37</wheel_separation>   <!-- 2 × 0.185 -->
      <wheel_radius>0.075</wheel_radius>
      <odom_publish_frequency>20</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <min_velocity>-1.5</min_velocity>
      <max_velocity>1.5</max_velocity>
      <min_acceleration>-3.0</min_acceleration>
      <max_acceleration>3.0</max_acceleration>
    </plugin>

  </model>  <!-- end robot -->

</world>
</sdf>
